venv/
env/
ENV/
.venv/

# ==============================
# Django Specific
# ==============================
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py

# Static & Media (generated files)
staticfiles/
media/

# ==============================
# Environment Variables
# ==============================
.env
.env.*
*.env

# ==============================
# Secrets / Keys
# ==============================
*.pem
*.key
*.crt

# ==============================
# Migrations (optional)
# ==============================
# Uncomment if you don't want migrations in repo
# */migrations/*
# !*/migrations/__init__.py

# ==============================
# IDE / Editor
# ==============================
.vscode/
.idea/
*.swp
*.swo

# ==============================
# OS Files
# ==============================
.DS_Store
Thumbs.db

# ==============================
# Testing / Coverage
# ==============================
htmlcov/
.coverage
.coverage.*
.cache
pytest_cache/

# ==============================
# Node (if using frontend tools)
# ==============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

